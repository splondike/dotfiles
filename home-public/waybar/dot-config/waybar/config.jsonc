{
    "layer": "top",
    "position": "bottom",
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-right": ["custom/backup", "cpu", "battery", "tray", "clock"],
    "cpu": {
        "format": "cpu: {usage}%"
    },
    "clock": {
         "format": "{:%Y-%m-%d %H:%M}"
    },
    "custom/backup": {
        "exec": "sh -c 'echo \"l: $(cat /var/log/backup_local_status) r: $(cat /var/log/backup_remote_status)\"'",
        "interval": 60
    }
}
